# Optional: enables Jooble searches for Europe, Sweden, and Bucharest.
JOOBLE_API_KEY=

# Optional comma-separated Company:board-token entries.
GREENHOUSE_BOARDS=

# Optional comma-separated Company:site entries.
LEVER_SITES=

# Required only for the external /api/cron/sync route.
CRON_SECRET=

# Required to protect the hosted dashboard.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Required. Neon Postgres pooled connection string (used by the app at runtime).
# On Vercel the Neon integration sets this automatically.
DATABASE_URL=

# Optional. Neon direct/unpooled string, used only by `npm run db:migrate`.
# Falls back to DATABASE_URL when unset.
DATABASE_URL_UNPOOLED=

# Optional: enables browser discovery only when set to 1.
JOB_RADAR_BROWSER_DISCOVERY=

# Optional pipe-separated https://www.linkedin.com/jobs/search URLs.
LINKEDIN_SEARCH_URLS=

# Optional discovery limits. Defaults and hard caps are shown below.
LINKEDIN_BOOTSTRAP_MAX_RESULTS=200
LINKEDIN_INCREMENTAL_MAX_RESULTS=100
LINKEDIN_MAX_DETAILS=80
GOOGLE_MAX_QUERIES=8
GOOGLE_MAX_PAGES=2

# Optional browser data paths. Relative paths resolve from the working directory.
JOB_RADAR_BROWSER_PROFILE_PATH=
JOB_RADAR_BROWSER_STATE_PATH=
